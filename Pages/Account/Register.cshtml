@page
@model artefact.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Register</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
            body {
                margin: 0;
                padding: 0;
                min-height: 100vh;
                background: url('/images/register-background.svg');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                display: flex;
                flex-direction: column;
            }

            .page-card {
                background: #ffffff;
                border-radius: 12px;
                padding: 2.5rem;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
                width: 100%;
                max-width: 420px;
                border: 2px solid #000000;
            }
    </style>
</head>
<body>
    <div class="d-flex justify-content-center align-items-center flex-grow-1">
        <div class="page-card">
            <h2 class="text-center mb-4">Register an Account</h2>

            <form method="post">
                <!-- Used to throw an error when something goes wrong -->
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Username Input -->
                <div class="mb-3">
                    <label asp-for="Username" class="form-label">Username</label>
                    <input asp-for="Username" type="text" class="form-control" placeholder="Your username" />
                    <!-- Throws an error when 'Username' is left empty as it is set to [Required] -->
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <!-- Email Input -->
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="name@emailprovider.com" />
                    <!-- Throws an error when 'Email' is left empty as it is set to [Required] -->
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- Password Input -->
                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Your password" />
                    <!-- Throws an error when 'Password' is left empty as it is set to [Required] -->
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Register</button>
            </form>

            <!-- Link to Login page -->
            <p class="mt-3 text-center">
                Already have an account? <a asp-page="/Account/Login">Login here</a>.
            </p>
        </div>
    </div>

</body>
</html>