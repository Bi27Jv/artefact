@page
@model artefact.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2 class="mb-4">Login</h2>

        <form method="post">
            <!-- Used to throw an error when something goes wrong -->
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Email Input -->
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="name@emailprovider.com" />
                <!-- Throws an error when 'Email' is left empty as it is set to [Required] -->
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- Password Input -->
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Your password" />
                <!-- Throws an error when 'Password' is left empty as it is set to [Required] -->
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Login</button>
        </form>

        <!-- Link to Registration page -->
        <p class="mt-3 text-center">
            Don't have an account? <a asp-page="/Account/Register">Register here</a>.   
        </p>
    </div>
</div>