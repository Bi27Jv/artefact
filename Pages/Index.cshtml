@page
@model artefact.Pages.IndexModel
@{
    ViewData["Title"] = "Home page";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Home</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background: url('/images/index-background.svg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            display: flex;
            flex-direction: column;
        }

        .top-navbar {
            background-color: #ffffff;
            border-bottom: 1px solid #dee2e6;
            padding: 0.75rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .page-card {
            background-color: #ffffff;
            border-radius: 12px;
            padding: 2.5rem;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
            width: 100%;
            max-width: 420px;
        }
    </style>
</head>
<body>
    <!-- Checks whether the user is logged in or not -->
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="container m-4">
            <div class="d-flex justify-content-center align-items-center flex-grow-1">
                <h2 class="text-center">My Projects:</h2>
                <a asp-page="/Projects/Create" class="btn btn-primary">+ Create New Project</a>
            </div>
            <!-- In case the user has not created any projects yet -->
            @if (Model.Projects.Count == 0)
                {
                <div class="d-flex justify-content-center align-items-center">
                    <div class="text-center">
                        <p>No projects found.</p>
                        <a asp-page="/Projects/Create" class="btn btn-primary btn-lg">Create your first project</a>
                    </div>
                </div>
                }
            <!-- If the user is logged in, and has availble projects, the site will then display them all in a grid -->
            else
                {
                    <div class="row row-cols-1 row-cols-md-3 g-4">
                        @foreach (var project in Model.Projects)
                        {
                            <div class="col">
                                <a asp-page="/Projects/Manage" asp-route-id="@project.Id" class="page-card">
                                    <h5 class="mb-2">@project.Name</h5>
                                    <p class="mb-2">@project.Description</p>
                                    <small>Created: @project.CreatedDate.ToString("dd MMM yyyy")</small>
                                </a>
                            </div>
                        }
                    </div>
                }

        </div>
    }
    <!-- If the user is not logged in, they will be greeted with a welcome message and prompted to create an account -->
    else
    {
        <div class="d-flex justify-content-center align-items-center flex-grow-1">
            <div class="page-card">
                <h1 class="text-center fw-bold mb-3">Welcome to the Project Managment Portal</h1>
                <p class="text-center">please login to view and manage projects</p>
                <div class="text-center">
                    <a asp-page="/Account/Login" class="btn btn-primary btn-lg me-2">Login</a>
                    <a asp-page="/Account/Register" class="btn btn-primary btn-lg me-2">Register an Account</a>
                </div>
            </div>
        </div>
    }
    <script>
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('message') == 'loggedout') {
            alert('You have been logged out successfully.');
        }
    </script>
</body>
</html>