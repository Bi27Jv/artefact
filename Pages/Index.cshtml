@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Home</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background: url('/images/index-background.svg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            display: flex;
            flex-direction: column;
        }

        .top-navbar {
            background-color: #ffffff;
            border-bottom: 1px solid #dee2e6;
            padding: 0.75rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .unknown-card {
            background-color: #ffffff;
            border-radius: 12px;
            padding: 2.5rem;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
            width: 100%;
            max-width: 420px;
        }
    </style>
</head>
<body>
    <div class="d-flex justify-content-center align-items-center flex-grow-1">
        <div class="unknown-card">
            <h1 class="text-center fw-bold mb-3">Welcome to the Project Managment Portal</h1>
            <p class="text-center">please login to view and manage projects</p>
            <div class="text-center">
                <a asp-page="/Account/Login" class="btn btn-primary btn-lg me-2">Login</a>
                <a asp-page="/Account/Register" class="btn btn-primary btn-lg me-2">Register an Account</a>
            </div>
        </div>
    </div>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('message') == 'loggedout') {
            alert('You have been logged out successfully.');
        }
    </script>
</body>
</html>