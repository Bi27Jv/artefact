@page "{id:int}" 
<!-- Sets the Page to the id of the Project to be Managed-->
@model artefact.Pages.Projects.ManageModel
@{
    ViewData["Title"] = Model.Project.Name;
    <!-- Used to Set the Page Title to the Project's Name -->
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Manage Project</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
            body {
                margin: 0;
                padding: 0;
                min-height: 100vh;
                background-image: url('/images/manage-background.svg');
                background-repeat: repeat;
                background-size: 200px 200px;
                background-color: #ffffff;
                display: flex;
                flex-direction: column;
            }

            .page-card {
                background-color: #ffffff;
                border-radius: 12px;
                padding: 2.5rem;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
                width: 100%;
                max-width: 420px;
            }
    </style>
</head>
<body>
    
</body>
</html>