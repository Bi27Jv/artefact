@page "{id:int}" 
<!-- Sets the Page to the id of the Project to be Managed-->
@model artefact.Pages.Projects.ManageModel
@{
    ViewData["Title"] = Model.Project.Name;
    <!-- Used to Set the Page Title to the Project's Name -->
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Manage Project</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
            body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background: url('/images/manage-background.svg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            display: flex;
            flex-direction: column;
        }

            .page-card {
                background-color: #ffffff;
                border-radius: 12px;
                padding: 2.5rem;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
                width: 100%;
                max-width: 420px;
                border: 2px solid #000000;
            }

            .content-card {
                border-left: 3px solid #000000;
                padding: 0.75rem 1rem;
                margin-bottom: 1rem;
                background-color: #ffffff;
                border-radius: 0 8px 8px 0;
            }
    </style>
</head>
<body>
    <div class="d-flex justify-content-center align-items-center flex-grow-1">
        <div class="page-card">
            <!-- Modify Project -->
            <h2 class="text-center mb-4">@Model.Project.Name</h2>
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Project Name Edit -->
                <div class="mb-3">
                    <label asp-for="Project.Name" class="form-label"></label>
                    <input asp-for="Project.Name" class="form-control" />
                    <span asp-validation-for="Project.Name" class="text-danger"></span>
                </div>

                <!-- Project Description Edit -->
                <div class="mb-3">
                    <label asp-for="Project.Description" class="form-label"></label>
                    <textarea asp-for="Project.Description" class="form-control" rows="4"></textarea>
                </div>

                <!-- Save Changes / Delete Project Button -->
                <div class="d-flex gap-2 mb-4">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <button type="submit" asp-page-handler="Delete" class="btn btn-danger"
                        onclick="return confirm('Are you sure you want to delete this project?')">
                        Delete Project
                    </button>
                </div>

            </form>

            <!-- Add Content to Project -->
            <h5 class="mb-3">Update Log</h5>

            <form method="post" asp-page-handler="AddContent">
                <div class="mb-3">
                    <label asp-for="NewContent" class="form-label">Add Update</label>
                    <textarea asp-for="NewContent" class="form-control" rows="3"
                        placeholder="Describe your progress here..."></textarea>
                </div>
                <button type="submit" class="btn btn-success">Add Update</button>
            </form>

            <!-- Display Existing Update Log -->
            @if (Model.Contents.Count == 0)
            {
                <p class="mt-3">Recorded Progress:</p>
            }
            else
            {
                @foreach (var content in Model.Contents)
                {
                    <div class="content-card">
                        <p class="mb-1">@content.Content</p>
                        <span class="text-muted">@content.CreatedDate.ToString("dd MM yyyy, HH:mm")</span>
                    </div>
                }
            }
        </div>
    </div>
</body>
</html>